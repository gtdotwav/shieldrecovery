{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/checkout",
      "destination": "https://checkout-mu-dun.vercel.app/checkout"
    },
    {
      "source": "/checkout/:path*",
      "destination": "https://checkout-mu-dun.vercel.app/checkout/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/worker/run",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/agent/orchestrate",
      "schedule": "*/5 * * * *"
    }
  ]
}
